# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase browser configuration
# Used by the frontend for auth and live audit subscriptions.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase server/worker configuration
# Required by the API and separate audit worker for privileged writes.
# Leave unset for local smoke tests that use the in-memory fallback.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel server-only blog generation and dispatch. Never use a VITE_ prefix.
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_BLOG_STRUCTURED_MODEL=openai/gpt-oss-120b
GROQ_BLOG_WRITER_MODEL=llama-3.3-70b-versatile
GROQ_BLOG_ENABLED=false
GROQ_BLOG_MAX_CONCURRENCY=1
GROQ_BLOG_MIN_REQUEST_INTERVAL_MS=2000
GROQ_BLOG_MAX_RETRIES=2
BLOG_FIXTURE_PROVIDER_ENABLED=false
ALLOW_BLOG_FIXTURE_GENERATION=false
BLOG_FIXTURE_STAGING_ONLY=false
ALLOW_PRODUCTION_BLOG_FIXTURE_GENERATION=false
BLOG_AUTOMATION_ENABLED=false
ALLOW_LIVE_BLOG_TEST=false
ALLOW_LIVE_BLOG_PUBLICATION_TEST=false
# Generate independent values of at least 24 characters in Vercel only.
BLOG_DISPATCH_SECRET=
CRON_SECRET=

# Optional local development flags
NODE_ENV=development
AUDIT_WORKER_ID=local-worker
AUDIT_POLL_INTERVAL_MS=4000
WORKER_RUNTIME=render-web-service
DEEP_AUDIT_ENABLED=false
ADMIN_EMAILS=
VITE_UPGRADE_URL=

# Production admission and abuse controls (server only)
RATE_LIMIT_HASH_SECRET=
GUEST_DAILY_AUDIT_LIMIT=2
DOMAIN_DAILY_AUDIT_LIMIT=2
GLOBAL_ACTIVE_AUDIT_LIMIT=50
API_JSON_BODY_LIMIT=64kb

# Optional bot-verification enforcement. Keep captchaRequired=false in
# platform settings until a matching browser widget is deployed.
TURNSTILE_SECRET_KEY=

# Optional build metadata. Vercel and Render supply commit identifiers.
BUILD_TIMESTAMP=
GIT_COMMIT_SHA=
