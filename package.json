{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "verify:seo": "node scripts/verify-seo-package.mjs",
    "smoke:seo": "node scripts/smoke-seo-audit.mjs",
    "verify:security": "node scripts/verify-security-package.mjs",
    "smoke:security": "tsx scripts/smoke-security-audit.ts",
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "smoke:live-audit": "tsx scripts/smoke-live-audit.mts",
    "smoke:api-json": "node scripts/smoke-api-json.mjs",
    "smoke:resource-light-audit": "tsx scripts/smoke-resource-light-audit.mjs",
    "smoke:supabase-schema": "node scripts/smoke-supabase-schema.mjs",
    "smoke:url": "tsx scripts/smoke-url-normalization.mjs",
    "e2e:local-audit": "node scripts/e2e-local-audit.mjs",
    "worker:audit": "tsx src/workers/audit-worker.ts",
    "worker:audit:dev": "tsx watch src/workers/audit-worker.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "d3-scale": "^4.0.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fuse.js": "^7.4.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.4",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^19.2.4",
    "react-simple-maps": "^3.0.0",
    "react-tooltip": "^5.30.0",
    "recharts": "^3.7.0",
    "stopword": "^3.1.5",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
