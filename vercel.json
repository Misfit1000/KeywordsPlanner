{
  "crons": [
    { "path": "/api/tools/blog/jobs/dispatch", "schedule": "15 3 * * *" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://seointel-audit-worker.onrender.com; frame-src 'none'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/index.js?path=tools/blog/sitemap.xml" },
    { "source": "/rss.xml", "destination": "/api/index.js?path=tools/blog/rss.xml" },
    { "source": "/news-sitemap.xml", "destination": "/api/index.js?path=tools/blog/news-sitemap.xml" },
    { "source": "/blog/:slug", "destination": "/api/index.js?path=tools/blog/html/:slug" },
    { "source": "/api/:path*", "destination": "/api/index.js?path=:path*" },
    { "source": "/pricing", "destination": "/index.html" },
    { "source": "/reports/example", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/register", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/acceptable-use", "destination": "/index.html" },
    { "source": "/cookies", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/blog", "destination": "/index.html" },
    { "source": "/blog/:path*", "destination": "/index.html" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/:path*", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/audit/live/:path*", "destination": "/index.html" }
  ]
}
